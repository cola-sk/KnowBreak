# === LLM (OpenAI 兼容协议) ===
# 任选一个：OpenAI / DeepSeek / 智谱 GLM / Qwen / Kimi
# 推荐 DeepSeek 或 GLM，国内直连稳定且便宜

# OpenAI 官方
# KB_LLM_BASE_URL=https://api.openai.com/v1
# KB_LLM_API_KEY=sk-...
# KB_LLM_MODEL=gpt-4o-mini

# DeepSeek
KB_LLM_BASE_URL=https://api.deepseek.com/v1
KB_LLM_API_KEY=sk-...
KB_LLM_MODEL=deepseek-chat

# 智谱 GLM
# KB_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# KB_LLM_API_KEY=...
# KB_LLM_MODEL=glm-4-flash

# === ASR ===
# 模式：openai | local
KB_ASR_PROVIDER=openai
# OpenAI 兼容音频转写接口；不填则使用 OpenAI SDK 默认配置
# KB_ASR_BASE_URL=https://api.openai.com/v1
# KB_ASR_API_KEY=sk-...
KB_ASR_MODEL=whisper-1
# 转写阶段会优先读取/下载字幕；只有找不到字幕时才调用 ASR
# 如果用 local (faster-whisper)，模型大小和设备
# KB_ASR_PROVIDER=local
# KB_ASR_LOCAL_MODEL=medium
# KB_ASR_LOCAL_DEVICE=cpu

# === 输出 ===
KB_OUT_DIR=./out

# === yt-dlp 下载配置（可选）===
# 当 YouTube/B 站等平台要求登录或触发 429 时使用。
# 优先推荐 cookies 文件；cookies.txt 是登录凭证，不要提交到 git。
# KB_COOKIES_FILE=./cookies.txt

# 备选：直接读取浏览器 cookies。YouTube 可能会检测并轮换 cookie，导致失效。
# 支持 chrome/safari/firefox/brave/edge 等 yt-dlp 支持的浏览器名。
# KB_COOKIES_BROWSER=chrome

# === TTS 配音（edge-tts，免费无需 key）===
# 中文音色默认 zh-CN-XiaoxiaoNeural，完整列表见
# https://learn.microsoft.com/azure/ai-services/speech-service/language-support
# KB_TTS_VOICE=zh-CN-XiaoxiaoNeural
# KB_TTS_RATE=+0%     # 语速，如 +10% / -5%
# KB_TTS_VOLUME=+0%   # 音量

# === 配图 provider（可选，不配置 key 则 compose 退化为纯色背景）===
# 默认按顺序尝试 Pexels → Pixabay；某个 provider 没有 key 会自动跳过。
# 想优先测试 Pixabay，可改成 pixabay,pexels。
KB_IMAGE_PROVIDERS=pexels,pixabay

# Pexels：申请 https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay：申请 https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# === 视频开头封面（可选）===
# 每个成片开头插入一张标题封面图；封面图跟随 KB_IMAGE_PROVIDERS 顺序。
KB_INTRO_ENABLED=true
KB_INTRO_DURATION=2.0
