# === LLM (OpenAI 兼容协议) ===
# 任选一个：OpenAI / DeepSeek / 智谱 GLM / Qwen / Kimi
# 推荐 DeepSeek 或 GLM，国内直连稳定且便宜

# OpenAI 官方
# KB_LLM_BASE_URL=https://api.openai.com/v1
# KB_LLM_API_KEY=sk-...
# KB_LLM_MODEL=gpt-4o-mini

# DeepSeek
KB_LLM_BASE_URL=https://api.deepseek.com/v1
KB_LLM_API_KEY=sk-...
KB_LLM_MODEL=deepseek-chat
# 单次 LLM 请求超时秒数；超时后流程会中断，保留已生成中间产物
KB_LLM_TIMEOUT=120

# 智谱 GLM
# KB_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# KB_LLM_API_KEY=...
# KB_LLM_MODEL=glm-4-flash

# === ASR ===
# 模式：openai | local
KB_ASR_PROVIDER=openai
# OpenAI 兼容音频转写接口；不填则使用 OpenAI SDK 默认配置
# KB_ASR_BASE_URL=https://api.openai.com/v1
# KB_ASR_API_KEY=sk-...
KB_ASR_MODEL=whisper-1
# 转写阶段会优先读取/下载字幕；只有找不到字幕时才调用 ASR
# 如果用 local (faster-whisper)，模型大小和设备
# KB_ASR_PROVIDER=local
# KB_ASR_LOCAL_MODEL=medium
# KB_ASR_LOCAL_DEVICE=cpu

# === 输出 ===
KB_OUT_DIR=./out

# === 风格 Profile ===
# profile 管 prompt、文案风格、LLM temperature、成片视觉样式等影响出片质量的参数。
# 内置：profiles/serious_science/profile.toml + prompts/*.md
KB_STYLE_PROFILE=serious_science
# 也可以直接指定一个自定义 profile 文件；相对路径按项目根目录解析。
# KB_STYLE_PROFILE_PATH=./profiles/my_style/profile.toml

# === yt-dlp 下载配置（可选）===
# 当 YouTube/B 站等平台要求登录或触发 429 时使用。
# 优先推荐 cookies 文件；cookies.txt 是登录凭证，不要提交到 git。
# KB_COOKIES_FILE=./cookies.txt

# 备选：直接读取浏览器 cookies。YouTube 可能会检测并轮换 cookie，导致失效。
# 支持 chrome/safari/firefox/brave/edge 等 yt-dlp 支持的浏览器名。
# KB_COOKIES_BROWSER=chrome

# === TTS 配音 ===
# provider: edge | openai | volcengine | minimax
# 非 edge provider 失败后会自动切到 edge 兜底。
KB_TTS_PROVIDER=edge
KB_TTS_TIMEOUT=60
KB_TTS_SPEED=1.0

# edge-tts（免费无需 key）
KB_TTS_VOICE=zh-CN-XiaoxiaoNeural
KB_TTS_RATE=+0%      # edge 专用语速，如 +10% / -5%
KB_TTS_VOLUME=+0%    # edge 专用音量

# OpenAI TTS
# KB_TTS_PROVIDER=openai
# KB_OPENAI_TTS_API_KEY=sk-...
# KB_OPENAI_TTS_BASE_URL=https://api.openai.com/v1
# KB_OPENAI_TTS_MODEL=gpt-4o-mini-tts
# KB_OPENAI_TTS_VOICE=alloy

# 火山引擎 / 豆包大模型语音合成 seed-tts-2.0
# KB_TTS_PROVIDER=volcengine
# KB_VOLC_TTS_API_KEY=
# KB_VOLC_TTS_MODEL=seed-tts-2.0
# KB_VOLC_TTS_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
# KB_VOLC_TTS_SPEAKER=zh_female_xiaohe_uranus_bigtts
# KB_VOLC_TTS_CONTEXT=自然、清晰、克制的中文科普男声，语速适中，不要背景音乐和音效。
# KB_VOLC_TTS_SAMPLE_RATE=24000
# KB_VOLC_TTS_SPEECH_RATE=0
# KB_VOLC_TTS_LOUDNESS_RATE=0
# KB_VOLC_TTS_PITCH_RATE=0

# MiniMax Speech
# KB_TTS_PROVIDER=minimax
# KB_MINIMAX_TTS_API_KEY=
# KB_MINIMAX_TTS_GROUP_ID=
# KB_MINIMAX_TTS_MODEL=speech-02-turbo
# KB_MINIMAX_TTS_VOICE_ID=Chinese (Mandarin)_News_Anchor
# KB_MINIMAX_TTS_URL=https://api.minimaxi.com/v1/t2a_v2

# === 配图 provider（可选，不配置 key 则 compose 退化为纯色背景）===
# 默认按顺序尝试 Pexels → Pixabay；某个 provider 没有 key 会自动跳过。
# 想优先测试 Pixabay，可改成 pixabay,pexels。
KB_IMAGE_PROVIDERS=pexels,pixabay

# Pexels：申请 https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay：申请 https://pixabay.com/api/docs/
PIXABAY_API_KEY=
